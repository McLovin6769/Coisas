import javax.swing.JOptionPane;
public class Main {
    public static void main(String[] args) {
        int num_des;
        int i = Integer.parseInt(JOptionPane.showInputDialog(null, "Digite 15 números. Você já digitou " + num_des));
        while (i > 100 && i < 200) {
            if (num_des == 15) {
                JOptionPane.showMessageDialog(null, "Dos " + num_des + " números digitados, " + i + " são maiores que 30.");
            }
        }
    }
}
