import javax.swing.JOptionPane;
public class Main {
    public static void main(String[] args) {
        int numero=0;
        int coconut=0;
        //declaração das variáveis
        for (numero=0; numero<= 15; numero++) {
            //for com a variável numero
            int i= Integer.parseInt(JOptionPane.showInputDialog(null,"Digite 15 números. Você já digitou"+numero));
            //dialogo com declaração de variavel int
           if(i>30){
               coconut++;
               //condição que mostra os numeros que são maiores no final
           }
            if (numero== 15) {
                //condição de ter 15 numeros digitados pra aparecer a telinha
                JOptionPane.showMessageDialog(null,"Dos 15 números digitados, "+coconut+"são maiores que 30.");
            }
        }
    }
}
